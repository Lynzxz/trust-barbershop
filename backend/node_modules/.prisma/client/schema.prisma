generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  password_hash   String
  full_name       String
  email           String    @unique
  phone           String?
  address         String?
  birth_date      DateTime?
  role            String    @default("member")
  profile_picture String?
  instagram       String?
  member_since    DateTime  @default(now())
  total_visits    Int       @default(0)
  total_spent     Decimal   @default(0) @db.Decimal(10, 2)
  loyalty_points  Int       @default(0)
  free_coupons    Int       @default(0)
  is_active       Boolean   @default(true)
  last_visit_date DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  visits        Visit[]
  transactions  Transaction[]
  notifications Notification[]
  loyaltyLogs   LoyaltyLog[]
}

model Barber {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  specialization String?
  avatar         String?
  instagram      String?
  is_active      Boolean  @default(true)
  total_clients  Int      @default(0)
  rating         Decimal  @default(0) @db.Decimal(3, 2)
  created_at     DateTime @default(now())

  visits Visit[]
}

model Package {
  id               String   @id @default(uuid())
  name             String
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  duration_minutes Int      @default(30)
  is_free          Boolean  @default(false)
  requires_coupon  Boolean  @default(false)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  visits       Visit[]
  transactions Transaction[]
}

model Visit {
  id               String   @id @default(uuid())
  user_id          String
  package_id       String
  barber_id        String?
  visit_date       DateTime @default(now())
  notes            String?
  rating           Int?
  review           String?
  payment_method   String?
  discount_amount  Decimal  @default(0) @db.Decimal(10, 2)
  used_free_coupon Boolean  @default(false)
  created_at       DateTime @default(now())

  user        User         @relation(fields: [user_id], references: [id])
  package     Package      @relation(fields: [package_id], references: [id])
  barber      Barber?      @relation(fields: [barber_id], references: [id])
  transaction Transaction?
}

model Transaction {
  id               String   @id @default(uuid())
  visit_id         String?  @unique
  user_id          String
  package_id       String
  amount           Decimal  @db.Decimal(10, 2)
  payment_method   String
  discount         Decimal  @default(0) @db.Decimal(10, 2)
  final_amount     Decimal  @db.Decimal(10, 2)
  transaction_date DateTime @default(now())
  created_at       DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  package Package @relation(fields: [package_id], references: [id])
  visit   Visit?  @relation(fields: [visit_id], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  event_date  DateTime
  start_time  String?
  end_time    String?
  location    String?
  is_active   Boolean  @default(true)
  created_by  String
  created_at  DateTime @default(now())
}

model ShopProfile {
  id              Int      @id @default(autoincrement())
  name            String   @default("Trust Barbershop")
  address         String?  @default("Tasikmalaya")
  phone           String?
  email           String?
  logo_url        String?
  operating_hours Json?
  is_open         Boolean  @default(true)
  loyalty_rule    Int      @default(7)
  updated_at      DateTime @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

model LoyaltyLog {
  id            String   @id @default(uuid())
  user_id       String
  action        String
  points_change Int
  description   String?
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}
